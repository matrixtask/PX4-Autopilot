# VTOL (Vertical Takeoff and Landing) configuration
param set-default VT_FWD_THRUST_EN 0
param set-default VT_FWD_THRUST_SC 0
param set-default VT_PITCH_MIN -5
# v7-fw: source-grounded transition tuning. ROOT CAUSE was VT_F_TR_OL_TM (default 6 s): the early
# quadchute (vtol_type.cpp:332) cancels the transition if airspeed < VT_ARSP_BLEND after this time, and the
# heavy Mk-7 can't reach a high blend airspeed in 6 s -> always quadchuted. Fix: long OL_TM + reachable
# blend/trans airspeeds + flaps deployed (lower stall ~37->32 m/s) so the sub-30 handoff is survivable.
# gentle pusher onset (slew 0.1 = ~8 s ramp) + moderate throttle 0.8 -> accelerate without the abrupt
# nose/roll upset that THR=1.0 caused at the transition start (the divergence was at ~8 m/s, full rotors).
param set-default VT_F_TRANS_THR 0.8
param set-default VT_PSHER_SLEW 0.1
param set-default VT_F_TRANS_DUR 15
param set-default VT_F_TR_OL_TM 30
param set-default VT_TRANS_TIMEOUT 30
param set-default VT_TRANS_MIN_TM 4
# keep lift rotors (attitude authority) until 28 m/s, then a TIGHT blend to 33 (above flapped stall ~28-32,
# where surfaces have enough q) -> bridges the transition valley in both lift AND roll authority.
param set-default VT_ARSP_BLEND 28
param set-default VT_ARSP_TRANS 33
param set-default VT_B_TRANS_DUR 10
# v7-fw recommendation #1: lift-rotor DIFFERENTIAL THRUST in FW (bitmask 7 = yaw+roll+pitch) keeps the
# rotors available for attitude authority through/after the transition -> bridges the low-q roll-authority
# gap that caused the hand-off roll-over, WITHOUT enlarging the (servo-feasible) ailerons. Reversible.
param set-default VT_FW_DIFTHR_EN 7
param set-default VT_FW_DIFTHR_S_R 2.0
param set-default VT_FW_DIFTHR_S_P 1.5
param set-default VT_FW_DIFTHR_S_Y 1.0
param set-default VT_TYPE 2
